# --- News APIs (all have free tiers) ---
# https://www.marketaux.com/  (100 req/day free)
MARKETAUX_API_KEY=
# https://finnhub.io/  (60 req/min free)
FINNHUB_API_KEY=
# https://newsdata.io/  (200 req/day free)
NEWSDATA_API_KEY=

# --- LLM ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Runtime ---
TZ=Europe/Prague
CRON_SCHEDULE=0 5 * * *
TICKERS=AAPL,MSFT,NVDA,GOOGL,AMZN,META,TSLA,BRK.B,JPM,XOM
PORT=3000

# Shared secret for POST /api/regenerate (leave empty to disable the endpoint)
REGENERATE_SECRET=
